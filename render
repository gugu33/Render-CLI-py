#!/bin/sh
# Render CLI wrapper script for Minis/iSH environment

SCRIPT_PATH="/var/minis/workspace/render_cli.py"

if [ ! -f "$SCRIPT_PATH" ]; then
    echo "Error: Render CLI script not found at $SCRIPT_PATH"
    echo "Make sure you're running this in Minis/iSH environment"
    exit 1
fi

if [ -z "$RENDER_API_KEY" ]; then
    echo "Error: RENDER_API_KEY environment variable is not set"
    echo "Set it using: export RENDER_API_KEY='your-api-key'"
    exit 1
fi

python3 "$SCRIPT_PATH" "$@"